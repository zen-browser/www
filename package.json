{
  "name": "www",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "pnpm": "^10.28.2"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "astro dev --port 3000",
    "start": "astro preview --port 3000",
    "build": "astro build",
    "preview": "astro preview --port 3000",
    "wrangler": "wrangler",
    "typecheck": "astro check",
    "lint": "eslint . --max-warnings=0 --cache",
    "lint:fix": "eslint . --fix",
    "spell": "cspell \"**/*.{ts,tsx,js,jsx,astro,md,json,yml,yaml}\"",
    "format": "prettier . --check --cache",
    "format:fix": "prettier . --write --cache --list-different",
    "commitlint": "commitlint --edit",
    "test": "vitest run",
    "test:coverage": "vitest --coverage",
    "test:playwright": "playwright test --reporter=list",
    "prepare": "lefthook install"
  },
  "pnpm": {
    "overrides": {
      "eslint-plugin-import>minimatch": "3.1.5"
    }
  },
  "dependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/cloudflare": "13.5.4",
    "@astrojs/react": "5.0.5",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "3.7.2",
    "@fontsource/bricolage-grotesque": "5.2.10",
    "@fortawesome/fontawesome-svg-core": "7.2.0",
    "@fortawesome/free-brands-svg-icons": "7.2.0",
    "@fortawesome/free-solid-svg-icons": "7.2.0",
    "@tailwindcss/vite": "4.3.0",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "animejs": "4.4.1",
    "astro": "6.3.7",
    "astro-navbar": "2.4.0",
    "clsx": "2.1.1",
    "date-fns": "4.2.1",
    "free-astro-components": "1.3.0",
    "jiti": "2.7.0",
    "lefthook": "2.1.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "sharp": "0.34.5",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.0",
    "turbo": "2.9.14",
    "typescript": "6.0.3",
    "ua-parser-js": "2.0.9"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@commitlint/cli": "21.0.0",
    "@commitlint/config-conventional": "21.0.0",
    "@cspell/dict-bash": "4.2.2",
    "@cspell/dict-css": "4.1.1",
    "@cspell/dict-es-es": "3.0.8",
    "@cspell/dict-html": "4.0.15",
    "@cspell/dict-node": "5.0.9",
    "@cspell/dict-npm": "5.2.38",
    "@cspell/dict-typescript": "3.2.3",
    "@cspell/eslint-plugin": "10.0.0",
    "@eslint/compat": "2.1.0",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.59.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/user-event": "14.6.1",
    "@types/animejs": "3.1.13",
    "@types/eslint-plugin-jsx-a11y": "6.10.1",
    "@types/jsdom": "28.0.3",
    "@types/node": "25.9.0",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "@typescript-eslint/parser": "8.59.2",
    "@typescript-eslint/utils": "8.59.2",
    "@vitest/coverage-istanbul": "4.1.5",
    "cspell": "10.0.0",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-astro": "1.7.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsonc": "3.1.2",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "jsdom": "29.1.1",
    "prettier": "3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "0.8.0",
    "typescript-eslint": "8.59.2",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.5",
    "wrangler": "^4.92.0"
  }
}
