---
const { class: classList } = Astro.props
---

<div id="circles" class:list={['pointer-events-none inset-0 overflow-hidden', classList]}>
  <div class="circles-lottie-wrapper mx-auto opacity-10 lg:opacity-100">
    <dotlottie-wc
      data-footer-lottie="dark"
      src="/lottie/logo_footer.lottie"
      autoplay
      loop
      style="width: 291px; height: 291px;"></dotlottie-wc>
    <dotlottie-wc
      data-footer-lottie="light"
      src="/lottie/logo_footer_light.lottie"
      autoplay
      loop
      style="width: 291px; height: 291px; display: none;"></dotlottie-wc>
  </div>
</div>

<script>
  import '@lottiefiles/dotlottie-wc'

  interface DotLottieInstance {
    setLoop(loop: boolean): void
    play(): void
    stop(): void
    resize(): void
    setFrame(frame: number): void
  }

  interface DotLottieElement extends HTMLElement {
    dotLottie?: DotLottieInstance
  }

  function updateFooterLottieVisibility() {
    const theme = document.documentElement.getAttribute('data-theme') || 'light'
    document.querySelectorAll('[data-footer-lottie]').forEach(el => {
      const variant = (el as HTMLElement).getAttribute('data-footer-lottie')
      const isVisible = variant === theme
      ;(el as HTMLElement).style.display = isVisible ? '' : 'none'

      // needed to correct dim after theme switch!!!
      if (isVisible && (el as DotLottieElement).dotLottie) {
        ;(el as DotLottieElement).dotLottie!.resize()
      }
    })
  }

  document.querySelectorAll('.circles-lottie-wrapper').forEach(wrapper => {
    wrapper.querySelectorAll<DotLottieElement>('dotlottie-wc').forEach(player => {
      function setup(lottie: DotLottieInstance) {
        lottie.setLoop(true)
        lottie.play()
      }

      if (player.dotLottie) {
        setup(player.dotLottie)
      } else {
        const events = ['dotlottie-ready', 'ready', 'load']
        const handler = () => {
          if (player.dotLottie) {
            events.forEach(e => player.removeEventListener(e, handler))
            setup(player.dotLottie)
          }
        }
        events.forEach(e => player.addEventListener(e, handler))
      }
    })
  })

  updateFooterLottieVisibility()

  // Catch theme changes
  const observer = new MutationObserver(mutations => {
    for (const mutation of mutations) {
      if (mutation.attributeName === 'data-theme') {
        updateFooterLottieVisibility()
      }
    }
  })
  observer.observe(document.documentElement, { attributes: true })
</script>

<style>
  .circles-lottie-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
  }
</style>
