---
const { class: className } = Astro.props
---

<div class:list={['logo-lottie-wrapper', className]}>
  <dotlottie-wc src="/lottie/logo_header.lottie" style="width: 32px; height: 32px"></dotlottie-wc>
</div>

<script>
  import '@lottiefiles/dotlottie-wc'

  interface DotLottieInstance {
    setLoop(loop: boolean): void
    play(): void
    stop(): void
    resize(): void
    setFrame(frame: number): void
  }

  interface DotLottieElement extends HTMLElement {
    dotLottie?: DotLottieInstance
  }

  document.querySelectorAll('.logo-lottie-wrapper').forEach(wrapper => {
    const player = wrapper.querySelector('dotlottie-wc') as DotLottieElement | null
    if (!player) return

    function setup(lottie: DotLottieInstance) {
      wrapper.addEventListener('mouseenter', () => {
        lottie.setFrame(0)
        lottie.play()
      })

      wrapper.addEventListener('mouseleave', () => {
        lottie.stop()
      })
    }

    // EExtra safety cause lottie player kept having issues with hover animation
    if (player.dotLottie) {
      setup(player.dotLottie)
    } else {
      const events = ['dotlottie-ready', 'ready', 'load']
      const handler = () => {
        if (player.dotLottie) {
          events.forEach(e => player.removeEventListener(e, handler))
          setup(player.dotLottie)
        }
      }
      events.forEach(e => player.addEventListener(e, handler))
    }
  })
</script>

<style>
  .logo-lottie-wrapper {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    cursor: pointer;
  }
</style>
