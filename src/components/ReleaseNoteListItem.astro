---
import { getLocale, getUI } from '~/utils/i18n'

interface Props {
  type: 'security' | 'feature' | 'fix' | 'theme' | 'break' | 'known' | 'change'
  content: string
  link?: {
    text: string
    href: string
  } | null
}

const { type, content, link } = Astro.props

const locale = getLocale(Astro)

const {
  routes: {
    releaseNotes: { itemType },
  },
} = getUI(locale)
---

<li class="flex gap-2">
  <div
    class="min-w-16 font-bold opacity-80"
    style={{ color: `var(--zen-color-${type})` }}
  >
    {itemType[type]}
  </div>
  <div>
    {content && <span class="text-base opacity-80" set:html={content} />}
    {
      link && (
        <span>
          <>
            {type === 'fix' && <span>{'('}</span>}
            <a href={link.href} class="text-blue inline-block text-base underline">
              {link.text}
            {/* prettier-ignore */}
            </a>{type === 'fix' && <span>{')'}</span>}
          </>
        </span>
      )
    }
  </div>
</li>
